# Required for GitHub Models embeddings (text-embedding-3-small)
# and Copilot SDK LLM calls.  Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# DATA_SOURCE=synthetic  (default — uses data/seed/*.json; this is what works today)
# DATA_SOURCE=workiq     (real connector = Microsoft's official MCP server "@microsoft/workiq",
#                         run via `npx -y @microsoft/workiq mcp`. Requires a PAID M365 Copilot
#                         license + tenant admin consent + a work/school account. NOT wired in
#                         this submission — ingest throws if set. See README "Data sources".)
DATA_SOURCE=synthetic

# Path to the SQLite database written by ingest and read by the server.
# db/runtime.db is gitignored; db/seed.db is the committed fixture.
DB_PATH=db/runtime.db
