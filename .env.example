# Required for GitHub Models embeddings (text-embedding-3-small)
# and Copilot SDK LLM calls.  Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# DATA_SOURCE=synthetic  (default — uses data/seed/*.json)
# DATA_SOURCE=workiq     (future — requires M365 Copilot license)
DATA_SOURCE=synthetic

# Path to the SQLite database written by ingest and read by the server.
# db/runtime.db is gitignored; db/seed.db is the committed fixture.
DB_PATH=db/runtime.db
